# bookin configuration
#
# Input dir is always /input, output dir is always /output (Docker volume mounts).
# Metadata is always fetched from Amazon via Calibre.
#
# Template uses Calibre Template Language (CTL) — same syntax as Calibre's
# "Save to disk" / "Send to device" feature.
# Common fields: {authors}, {title}, {series}, {series_index}, {publisher}, {pubdate}
# See: https://manual.calibre-ebook.com/template_lang.html

template: "{authors}/{series:||/}{title}"
log_level: INFO
